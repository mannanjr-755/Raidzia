{
  "version": 2,
  "installCommand": "cd ../.. && npm install --include=dev",
  "buildCommand": "cd ../.. && npm run build:api",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "dist/**",
          "prisma/**",
          "../../node_modules/.prisma/**",
          "../../node_modules/@prisma/client/**"
        ]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "api/index.js" }]
}
