{
  "name": "rss-erp",
  "version": "1.0.0",
  "private": true,
  "description": "RSS Construction ERP - Rehan Shahid & Sons Builders & Developers",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx scripts/run-dev.ts",
    "dev:api": "npm run dev --workspace=@rss/api",
    "dev:web": "npm run dev --workspace=@rss/web",
    "dev:legacy": "next dev",
    "postinstall": "tsx scripts/postinstall.ts",
    "db:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "prisma:generate": "tsx scripts/postinstall.ts",
    "build": "tsx scripts/build-full.ts",
    "build:root": "npx prisma generate --schema=prisma/schema.prisma && next build",
    "build:web": "npm run build --workspace=@rss/shared && npm run build --workspace=@rss/web",
    "build:netlify": "tsx scripts/build-cdn.ts",
    "build:cdn": "tsx scripts/build-cdn.ts",
    "build:vercel": "tsx scripts/build-vercel.ts",
    "build:api": "npm run build --workspace=@rss/shared && npm run build --workspace=@rss/api",
    "build:legacy": "prisma generate --schema=prisma/schema.prisma && next build",
    "verify:build": "tsx scripts/verify-build.ts",
    "verify:cdn": "tsx scripts/verify-no-private-rewrites.ts",
    "start": "tsx scripts/run-prod.ts",
    "start:api": "npm run start --workspace=@rss/api",
    "start:web": "npm run start --workspace=@rss/web",
    "start:legacy": "next start",
    "db:start": "tsx scripts/start-postgres.ts",
    "db:create": "tsx scripts/create-db.ts",
    "db:setup": "npm run db:create && npm run db:push --workspace=@rss/api && npm run db:seed --workspace=@rss/api",
    "check:services": "tsx scripts/check-services.ts",
    "db:studio": "npm run db:studio --workspace=@rss/api"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.3.1",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.469.0",
    "next": "^15.1.4",
    "next-themes": "^0.4.4",
    "pdfkit": "^0.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "sonner": "^1.7.2",
    "tailwind-merge": "^2.6.0",
    "tsx": "^4.23.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.13.9",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "dotenv": "^16.6.1",
    "embedded-postgres": "^17.10.0-beta.17",
    "eslint": "9.39.5",
    "eslint-config-next": "15.5.20",
    "postcss": "^8.4.49",
    "prisma": "^6.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
