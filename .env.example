# =============================================================================
# RSS Construction ERP — Environment Variables
# =============================================================================
#
# This file documents ALL environment variables used by the project.
# Copy to .env or .env.local and fill in production values.
#
# Active stack: apps/web (Next.js :3000) + apps/api (Express :4000)
# Legacy root Next.js app also uses some of these (SESSION_SECRET).

# --- Database (required) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rss_erp?schema=public"

# --- JWT / Auth (required for API) ---
# Must be strong, unique, and at least 32 characters each.
JWT_SECRET=change-this-jwt-secret-in-production-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Session (required for root Next.js app) ---
SESSION_SECRET=change-this-session-secret-in-production-min-32-chars

# --- API Server ---
API_PORT=4000
# Comma-separated browser origins allowed to call the API directly.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Set TRUST_PROXY=1 behind nginx/load balancers.
# TRUST_PROXY=1

# --- Frontend (apps/web) ---
# Browser API base URL.
# Local / same-host (Railway, Render, Docker): keep /api (Next rewrites to API_ORIGIN).
NEXT_PUBLIC_API_URL=/api
API_ORIGIN=http://127.0.0.1:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Netlify / Vercel (frontend CDN only) ---
# NEVER use 127.0.0.1 or localhost here — causes DNS_HOSTNAME_RESOLVED_PRIVATE.
# Set the PUBLIC HTTPS URL of your separately deployed API:
#   NEXT_PUBLIC_API_URL=https://your-api.onrender.com/api
#   CORS_ORIGINS=https://your-site.netlify.app   (on the API host)
# Deploy API with: npm run build:api && npm run start:api (Railway/Render/VPS).

# --- Docker Compose ---
# When using docker-compose.yml, set these in the API service environment:
#   DATABASE_URL=postgresql://rss_user:rss_password@postgres:5432/rss_erp?schema=public
#   CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# And in the web service environment:
#   API_ORIGIN=http://api:4000

# --- Hosting (full-stack: API + Web together) ---
# Railway / Render / Docker / VPS — use:
#   Build: npm ci && npm run build
#   Start: npm start
# See railway.toml, render.yaml, or Dockerfile.
#
# Split hosting (frontend-only platforms):
# Netlify / Vercel cannot run Express. Deploy API separately, then set:
#   API_ORIGIN=https://api.yourdomain.com
#   CORS_ORIGINS=https://your-frontend.netlify.app

# --- Optional services ---
# REDIS_URL=redis://localhost:6379
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# OPENAI_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
