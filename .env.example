# =============================================================================
# RSS Construction ERP — Environment
# Active stack: apps/web (Next.js :3000) + apps/api (Express :4000)
# =============================================================================

# --- Required ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# JWT (API) — must be strong and DIFFERENT from each other
JWT_SECRET=change-this-jwt-secret-in-production-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- API ---
API_PORT=4000
# Comma-separated browser origins allowed to call the API directly
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Set TRUST_PROXY=1 behind nginx/load balancers
# TRUST_PROXY=1

# --- Frontend (apps/web) ---
# Browser calls same-origin /api; Next.js rewrites to API_ORIGIN (build-time for rewrites)
NEXT_PUBLIC_API_URL=/api
API_ORIGIN=http://127.0.0.1:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Docker Compose (web → api service name):
#   API_ORIGIN=http://api:4000
# Vercel (frontend only): set API_ORIGIN to your public API URL, e.g.:
#   API_ORIGIN=https://api.yourdomain.com
# and deploy the API separately (Docker / VPS). Vercel cannot run Express.
#
# Netlify (frontend only — Express API CANNOT run on Netlify):
#   API_ORIGIN=https://api.yourdomain.com
#   NEXT_PUBLIC_API_URL=/api
#   NEXT_PUBLIC_APP_URL=https://your-site.netlify.app
#   Deploy API separately (Render/Railway/VPS). Set CORS_ORIGINS on API to your Netlify URL.
#   Or set NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api for direct API calls.

# --- Legacy root Next.js app only (optional) ---
SESSION_SECRET="replace-with-a-random-32-byte-or-longer-secret"

# --- Optional services ---
REDIS_URL="redis://localhost:6379"

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

OPENAI_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
