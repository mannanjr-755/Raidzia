# Required in production
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
SESSION_SECRET="replace-with-a-random-32-byte-or-longer-secret"

# Optional local cache/service URLs
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=change-this-jwt-secret-in-production-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API
API_PORT=4000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
NEXT_PUBLIC_API_URL=/api
API_ORIGIN=http://127.0.0.1:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenAI for AI Advisor (optional)
OPENAI_API_KEY=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
